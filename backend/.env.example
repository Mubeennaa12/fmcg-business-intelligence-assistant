# Database configuration
# For SQLite: sqlite:///./fmcg_beverages.db
# For PostgreSQL: postgresql://username:password@host:port/database
DATABASE_URL=sqlite:///./fmcg_beverages.db

# LLM API Keys (At least one is required for full AI functionalities)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# App settings
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
